    <model name="iris_with_ardupilot">
      <pose>-3 2.5 0.195 0 0 0</pose>

      <link name="base_link">
        <inertial>
          <pose>0 0 0.06 0 0 0</pose>
          <mass>1.5</mass>
          <inertia>
            <ixx>0.0347563</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.0458929</iyy><iyz>0</iyz>
            <izz>0.0806</izz>
          </inertia>
        </inertial>

        <collision name="base_collision">
          <pose>0 0 0.06 0 0 0</pose>
          <geometry><box><size>0.18 0.18 0.10</size></box></geometry>
        </collision>
        <visual name="body_vis">
          <pose>0 0 0.06 0 0 0</pose>
          <geometry><box><size>0.18 0.18 0.10</size></box></geometry>
          <material><ambient>0.15 0.15 0.15 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse></material>
        </visual>
        <visual name="arm_fr_vis"><pose>0.11 -0.11 0.06 0 0 -0.7854</pose><geometry><box><size>0.31 0.025 0.02</size></box></geometry><material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.15 0.15 0.15 1</diffuse></material></visual>
        <visual name="arm_fl_vis"><pose>0.11 0.11 0.06 0 0 0.7854</pose><geometry><box><size>0.31 0.025 0.02</size></box></geometry><material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.15 0.15 0.15 1</diffuse></material></visual>
        <visual name="arm_rr_vis"><pose>-0.11 -0.11 0.06 0 0 0.7854</pose><geometry><box><size>0.31 0.025 0.02</size></box></geometry><material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.15 0.15 0.15 1</diffuse></material></visual>
        <visual name="arm_rl_vis"><pose>-0.11 0.11 0.06 0 0 -0.7854</pose><geometry><box><size>0.31 0.025 0.02</size></box></geometry><material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.15 0.15 0.15 1</diffuse></material></visual>
        <visual name="mount_0_vis"><pose>0.13 -0.22 0.07 0 0 0</pose><geometry><cylinder><radius>0.02</radius><length>0.04</length></cylinder></geometry><material><ambient>0.1 0.1 0.1 1</ambient></material></visual>
        <visual name="mount_1_vis"><pose>-0.13 0.22 0.07 0 0 0</pose><geometry><cylinder><radius>0.02</radius><length>0.04</length></cylinder></geometry><material><ambient>0.1 0.1 0.1 1</ambient></material></visual>
        <visual name="mount_2_vis"><pose>0.13 0.22 0.07 0 0 0</pose><geometry><cylinder><radius>0.02</radius><length>0.04</length></cylinder></geometry><material><ambient>0.1 0.1 0.1 1</ambient></material></visual>
        <visual name="mount_3_vis"><pose>-0.13 -0.22 0.07 0 0 0</pose><geometry><cylinder><radius>0.02</radius><length>0.04</length></cylinder></geometry><material><ambient>0.1 0.1 0.1 1</ambient></material></visual>

        <sensor name="imu_sensor" type="imu">
          <always_on>true</always_on>
          <update_rate>1000</update_rate>
          <imu>
            <angular_velocity>
              <x><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></x>
              <y><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></y>
              <z><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></z>
            </angular_velocity>
            <linear_acceleration>
              <x><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></x>
              <y><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></y>
              <z><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></z>
            </linear_acceleration>
          </imu>
        </sensor>

        <!-- FIX 1 & 2: gpu_lidar → gpu_ray, topic stays same -->
        <sensor name="lidar_front" type="gpu_ray">
          <pose>0.12 0 0.05 0 0 0</pose>
          <always_on>true</always_on><update_rate>10</update_rate><visualize>false</visualize>
          <topic>/drone/lidar_front</topic>
          <ray>
            <scan><horizontal><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></horizontal></scan>
            <range><min>0.1</min><max>30.0</max><resolution>0.01</resolution></range>
            <noise><type>gaussian</type><mean>0.0</mean><stddev>0.005</stddev></noise>
          </ray>
        </sensor>

        <sensor name="sonar_left" type="gpu_ray">
          <pose>0 0.12 0.05 0 0 1.5708</pose>
          <always_on>true</always_on><update_rate>10</update_rate><visualize>false</visualize>
          <topic>/drone/sonar_left</topic>
          <ray>
            <scan><horizontal><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></horizontal></scan>
            <range><min>0.02</min><max>4.5</max><resolution>0.01</resolution></range>
            <noise><type>gaussian</type><mean>0.0</mean><stddev>0.01</stddev></noise>
          </ray>
        </sensor>

        <sensor name="sonar_right" type="gpu_ray">
          <pose>0 -0.12 0.05 0 0 -1.5708</pose>
          <always_on>true</always_on><update_rate>10</update_rate><visualize>false</visualize>
          <topic>/drone/sonar_right</topic>
          <ray>
            <scan><horizontal><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></horizontal></scan>
            <range><min>0.02</min><max>4.5</max><resolution>0.01</resolution></range>
            <noise><type>gaussian</type><mean>0.0</mean><stddev>0.01</stddev></noise>
          </ray>
        </sensor>
